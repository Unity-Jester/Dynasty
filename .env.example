# Your Sleeper league ID (League Settings in the Sleeper app)
NEXT_PUBLIC_LEAGUE_ID=your_league_id_here

# Optional: override the CSV export URL for historical player/pick values.
# Defaults to the shared community Google Sheet.
# HISTORICAL_VALUES_CSV_URL=https://docs.google.com/spreadsheets/d/<id>/export?format=csv&gid=<gid>

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
DATABASE_URL=            # Supabase "Transaction pooler" connection string
CRON_SECRET=             # random string; GitHub Actions sends it as Authorization: Bearer
NEXT_PUBLIC_SITE_URL=    # e.g. https://dynasty.example.com; used for auth redirect URLs
